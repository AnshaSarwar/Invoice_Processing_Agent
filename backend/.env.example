# API Keys
# Get your keys from https://console.groq.com/, https://aistudio.google.com/, and https://cloud.llamaindex.ai/
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# AI Observability (LangSmith)
# Get your key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT="invosync-prod"

# Database Configuration
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invosync_db

# Processing Settings
MAX_REFLECTIONS=2
REFLECTION_CONFIDENCE_THRESHOLD=0.7
FUZZY_MATCH_THRESHOLD=85
MAX_FILE_SIZE_MB=10

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
